# ============================================================
# NeuroX — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER put real credentials in this file.
# NEVER commit .env.local to source control.
# ============================================================


# ------------------------------------------------------------
# Database — Azure SQL
# ------------------------------------------------------------
DB_SERVER=your-server.database.windows.net
DB_NAME=your-database-name
DB_USER=your-db-username
DB_PASSWORD=your-db-password


# ------------------------------------------------------------
# Authentication
# Generate a strong secret: openssl rand -base64 48
# ------------------------------------------------------------
AUTH_JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars
# Legacy alias — keep in sync with AUTH_JWT_SECRET
JWT_SECRET=


# ------------------------------------------------------------
# Agent5i — AI Agent Platform
# Primary credentials used by all AI generation routes.
# ------------------------------------------------------------
AGENT5I_USERNAME=your-agent5i-email@example.com
AGENT5I_PASSWORD=your-agent5i-password

# Webhook URL — swap dev/prod here instead of in code.
# Dev:  https://agent5idev.c5ailabs.com/api/recipes/webhook/agent/
# Prod: https://agent5i.c5ailabs.com/api/recipes/webhook/agent/
AGENT5I_WEBHOOK_URL=https://agent5i.c5ailabs.com/api/recipes/webhook/agent/

# Legacy aliases used by older routes — keep in sync with AGENT5I_* above
AGENT_USERNAME=
AGENT_PASSWORD=

# ------------------------------------------------------------
# Agent5i — Named Agent Overrides (optional)
# These default to the values below; only set them to override.
# ------------------------------------------------------------
AGENT5I_PERSONA_AGENT_NAME=User Persona Enhancer
AGENT5I_QUESTION_AGENT_NAME=User Group Question Generator
AGENT5I_PERSONA_GENERATOR_AGENT_NAME=Persona Generator Agent
AGENT5I_SUMMARY_AGENT_NAME=Research Summary Agent
AGENT5I_IA_AGENT_NAME=IA Agent
AGENT5I_APP_PROMPT_AGENT_NAME=Prompt Generator Agent
AGENT5I_BRD_AGENT_NAME=BRD Generator
AGENT5I_PRD_AGENT_NAME=AI PRD Generator
AGENT5I_WIREFRAME_AGENT_NAME=wireframe_analyzer_agent


# ------------------------------------------------------------
# Azure Blob Storage — file/document uploads
# ------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONTAINER_NAME=your-container-name
# How long (minutes) a generated SAS token stays valid (default: 60)
AZURE_STORAGE_SAS_EXPIRY_MINUTES=60


# ------------------------------------------------------------
# Google Generative AI (Gemini)
# ------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key


# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NODE_ENV is set automatically by Next.js — do not override here
